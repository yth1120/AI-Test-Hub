# ===== AI TestHub 环境变量模板（Next.js + PostgreSQL）=====
# 复制为 .env 后填写。部署见 DEPLOY.md。

# ===== PostgreSQL =====
# 数据库密码。docker-compose 的 db 和 app 服务都读这个变量（默认 123456）。
# 生产务必改强密码：openssl rand -hex 16
DB_PASSWORD="123456"
# 本地开发直连库时用（容器内 app 不读这条，它在 compose 里用服务名 db 拼接）。
# 改了 DB_PASSWORD 后，这里的密码也要同步改成一样。
DATABASE_URL="postgresql://testhub:123456@localhost:5432/testhub?schema=public"

# Auth.js / NextAuth
# 生成：openssl rand -base64 32   或   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# ===== AI 服务端 Key（按 provider，lib/ai-keys.ts 读取）=====
# 在「项目设置」里选 aiProvider，对应这里的 Key 生效；留空则该 provider 回退到 mock 内容。
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_GENERATIVE_AI_API_KEY=""
# 以下三家兼容 OpenAI 协议（baseURL 已在 ai-service 内置默认值，可在项目设置覆盖）
DEEPSEEK_API_KEY=""
KIMI_API_KEY=""
QWEN_API_KEY=""

# ===== 入站 Webhook 密钥 =====
# junit/github webhook 鉴权。生成：openssl rand -hex 32
# - junit：调用时带 ?secret=<此值>
# - github：在 GitHub Webhook 设置里填同一值，用 x-hub-signature-256 HMAC 校验
# 未配置时，所有入站 webhook 返回 503（拒绝）。
WEBHOOK_SECRET=""

# ===== Agent 沙盒 =====
# 完整工作流的「脚本执行」阶段是否在服务器真实执行 AI 生成的代码。
# 默认关闭（安全）。设为 true 才执行（需服务器已安装 python）。切勿用于执行不可信代码。
AGENT_SANDBOX_ENABLED="false"
